# Server Port
PORT=5000

# Google Authentication
# Go to https://console.cloud.google.com to create your Client ID
GOOGLE_CLIENT_ID=GET_YOUR_CLIENT_ID_FROM_GOOGLE_CONSOLE

# Security (Change this in production)
JWT_SECRET=your-super-secret-key-change-this-in-prod

# Email Configuration (For account verification)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-google-app-password

# Application URL
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
