{
  "manifest_version": 3,
  "name": "Ranking Anywhere — Smart Checker",
  "version": "2.0.0",
  "description": "Professional distributed ranking assistant. Silently checks your Google positions from your own browser.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting",
    "offscreen"
  ],
  "host_permissions": [
    "https://www.google.com/*",
    "https://www.google.co.in/*",
    "https://www.google.com.au/*",
    "https://www.google.co.uk/*",
    "https://www.google.ca/*",
    "https://www.google.de/*",
    "https://www.google.fr/*",
    "https://www.google.es/*",
    "https://www.google.co.jp/*",
    "https://www.google.com.br/*",
    "https://www.google.ae/*",
    "http://localhost:5000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
